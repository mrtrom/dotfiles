#!/usr/bin/env bash

_fzf_compgen_path() {
  ag -g "" "$1"
}

# ── Magic Enter ───────────────────────────────────────────────────────────────
# Pressing Enter on a blank prompt runs `git status` (in a git repo) or `eza`
magic-enter() {
  if [[ -z "$BUFFER" ]]; then
    if git rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
      BUFFER="git status --short"
    else
      BUFFER="eza --icons --group-directories-first -la"
    fi
  fi
  zle .accept-line
}
zle -N accept-line magic-enter

# ── Yazi (file manager with cwd integration) ──────────────────────────────────
# Using `y` instead of `yazi` changes your shell directory when you quit yazi
y() {
  local tmp
  tmp="$(mktemp -t yazi-cwd)"
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

# ── Cursor extensions sync ────────────────────────────────────────────────────
# Save current extensions to the tracked list
cursor-save-extensions() {
  cursor --list-extensions | sort > "$HOME/Library/Application Support/Cursor/User/extensions.txt"
  echo "Saved $(wc -l < "$HOME/Library/Application Support/Cursor/User/extensions.txt" | tr -d ' ') extensions"
}

# Install all extensions from the tracked list
cursor-install-extensions() {
  local ext_file="$HOME/Library/Application Support/Cursor/User/extensions.txt"
  [[ ! -f "$ext_file" ]] && echo "No extensions.txt found" && return 1
  while IFS= read -r ext; do
    [[ -z "$ext" ]] && continue
    cursor --install-extension "$ext"
  done < "$ext_file"
}

# ── Completion caching ────────────────────────────────────────────────────────
# Cache output of slow completion-generating commands for 24h.
# Usage: _cached_completion pip completion --zsh
_cached_completion() {
  local cache_dir="$HOME/.zsh_comp_cache"
  local cache="$cache_dir/$1"
  mkdir -p "$cache_dir"
  if [[ ! -f "$cache" ]] || [[ -n "$(find "$cache" -mtime +1 2>/dev/null)" ]]; then
    "$@" > "$cache" 2>/dev/null
  fi
  source "$cache"
}
