Host *
    PubkeyAcceptedKeyTypes=+ssh-rsa
    HostKeyAlgorithms=+ssh-rsa
    # Auto-load keys into ssh-agent on first use
    AddKeysToAgent yes
    IdentityFile ~/.ssh/id_rsa

Host *.deckardinfra.net
    User mrtrom
    ForwardAgent yes
    ControlMaster auto
    ControlPath ~/.ssh/socket-%h
    ControlPersist 3600
    ServerAliveInterval 300
    ServerAliveCountMax 2
